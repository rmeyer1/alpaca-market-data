# Alpaca Market Data SDK - Environment Variables
# Copy this file to .env and fill in your actual API credentials
# DO NOT commit .env to version control!

# Alpaca API Credentials (required)
# Get your API keys from: https://app.alpaca.markets/paper/dashboard
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# API Configuration (optional)
# Use 'https://paper-api.alpaca.markets' for paper trading
# Use 'https://api.alpaca.markets' for live trading
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Market Data Feed (optional)
# Options: iex, sip
# iex = IEX feed (free tier)
# sip = SIP feed (paid tier, requires subscription)
ALPACA_DATA_FEED=iex

# Rate Limiting (optional)
# Default: 200 requests per minute for Alpaca API
ALPACA_MAX_REQUESTS_PER_MINUTE=200

# Logging (optional)
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Output Format (optional)
# Default output format for CLI scripts: json, csv, dataframe
DEFAULT_OUTPUT_FORMAT=json
